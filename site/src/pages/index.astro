---
import Base from "../layouts/Base.astro";
import ConfidenceBadge from "../components/ConfidenceBadge.astro";
import { loadRegions, loadConsoles, loadMeta, formatUnits, formatDate } from "../lib/data";

const regions = loadRegions();
const allConsoles = loadConsoles();
const meta = loadMeta();
const global = regions.find((r) => r.slug === "global")!;
const top10 = global.leaderboard.slice(0, 10);
const totalUnits = global.leaderboard.reduce((s, r) => s + r.units_cumulative, 0);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const leaderboardSlugs = new Set(global.leaderboard.map((r) => r.console_slug));
const noFigure = allConsoles.filter((c) => !leaderboardSlugs.has(c.slug));
const chartData = top10.map((r) => ({
  label: r.display_name,
  value: r.units_cumulative,
  confidence: r.confidence,
}));
---
<Base title="Global console sales">
  <h2 style="margin-top:0;">Global console sales</h2>
  <p class="lede">
    Every major game console tracked, aggregated from first-party investor data where available and
    credible analyst estimates elsewhere. Every figure below links to its source.
  </p>

  <div class="pills">
    <span class="pill"><strong>{formatUnits(totalUnits)}</strong>&nbsp;units tracked globally</span>
    <span class="pill"><strong>{meta.total_consoles}</strong>&nbsp;consoles</span>
    <span class="pill"><strong>{meta.total_facts}</strong>&nbsp;facts</span>
    <span class="pill">Last generated: {formatDate(meta.generated_at)}</span>
  </div>

  <div class="chart-wrap" style="height: 380px;">
    <canvas id="top10"></canvas>
  </div>

  <h2>Global leaderboard</h2>
  <table class="leaderboard">
    <thead>
      <tr>
        <th>#</th>
        <th>Console</th>
        <th>Manufacturer</th>
        <th style="text-align:right;">Units (cumulative)</th>
        <th>as of</th>
        <th>Source</th>
      </tr>
    </thead>
    <tbody>
      {global.leaderboard.map((row, i) => (
        <tr>
          <td>{i + 1}</td>
          <td><a href={`${base}/console/${row.console_slug}`}>{row.display_name}</a></td>
          <td>{row.manufacturer}</td>
          <td class="num">{formatUnits(row.units_cumulative)}</td>
          <td>{formatDate(row.period_end)}</td>
          <td>
            <ConfidenceBadge confidence={row.confidence} />
            <a href={row.source_url} rel="noopener noreferrer">{row.source_key}</a>
          </td>
        </tr>
      ))}
    </tbody>
  </table>

  {noFigure.length > 0 && (
    <>
      <h2>Tracked, no separate sales disclosure</h2>
      <p class="lede">
        These consoles are tracked but their manufacturers don't break out unit sales separately —
        either because sales are bundled into a family total (e.g. PS5 Pro rolled into the PS5 family)
        or because the vendor simply doesn't publish handheld unit numbers. Click through for launch
        info and context.
      </p>
      <table class="leaderboard">
        <thead>
          <tr><th>Console</th><th>Manufacturer</th><th>Launched</th><th>Why unlisted</th></tr>
        </thead>
        <tbody>
          {noFigure.map((c) => (
            <tr>
              <td><a href={`${base}/console/${c.slug}`}>{c.display_name}</a></td>
              <td>{c.manufacturer}</td>
              <td>{formatDate(c.launch_date)}</td>
              <td style="color:var(--text-dim);font-size:0.88rem;">{c.notes || "No public figure."}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </>
  )}

  <p class="lede" style="margin-top:2rem;">
    Drill into a region:
    {regions.filter((r) => r.slug !== "global").map((r, i, arr) => (
      <>
        <a href={`${base}/region/${r.slug}`}>{r.display_name}</a>{i < arr.length - 1 ? " · " : ""}
      </>
    ))}
  </p>

  <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.6/dist/chart.umd.min.js"></script>
  <script is:inline define:vars={{ chartData }}>
    window.addEventListener("DOMContentLoaded", () => {
      const ctx = document.getElementById("top10");
      if (!ctx || !window.Chart) return;
      const colorFor = (conf) => ({
        official: "#22c55e",
        press_leak: "#f59e0b",
        analyst_estimate: "#60a5fa",
        derived: "#a78bfa",
      }[conf] || "#4fc3ff");
      new window.Chart(ctx, {
        type: "bar",
        data: {
          labels: chartData.map((d) => d.label),
          datasets: [{
            label: "Units (millions)",
            data: chartData.map((d) => d.value / 1_000_000),
            backgroundColor: chartData.map((d) => colorFor(d.confidence)),
            borderRadius: 4,
          }],
        },
        options: {
          indexAxis: "y",
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { display: false } },
          scales: {
            x: { ticks: { color: "#9aa6b2", callback: (v) => v + " M" }, grid: { color: "#1c2531" } },
            y: { ticks: { color: "#e6edf3" }, grid: { display: false } },
          },
        },
      });
    });
  </script>
</Base>
